{
  "manifest_version": 3,
  "name": "FlowRead AI",
  "version": "1.1",
  "description": "Accelerate reading comprehension using LLM attention vectors.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://jobbler-flowread.hf.space/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FlowRead AI Settings"
  },
  "commands": {
    "flowread-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "FlowRead the entire page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}